#!/bin/bash
# Configure Nginx to run as nginx user on port 8080

# Ensure nginx user exists
id -u nginx &>/dev/null || adduser --system --no-create-home --shell /bin/false nginx

# Update nginx.conf
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf
sed -i 's/listen .*/listen 8080;/' /etc/nginx/sites-enabled/default

# Start Nginx as nginx user
exec su -s /bin/sh -c "nginx -g 'daemon off;'" nginx

