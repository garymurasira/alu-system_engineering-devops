#!/usr/bin/env bash
# Configures a new Ubuntu machine with nginx and a custom HTTP response header

apt-get update -y
apt-get install -y nginx

mkdir -p /var/www/html
echo "Holberton School" > /var/www/html/index.html
echo "Ceci n'est pas une page" > /var/www/html/404.html

sed -i '/server_name _;/a \\tadd_header X-Served-By $HOSTNAME;' /etc/nginx/sites-available/default
sed -i '/server_name _;/a \\terror_page 404 /404.html;' /etc/nginx/sites-available/default
sed -i '/server_name _;/a \\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}' /etc/nginx/sites-available/default

service nginx start
nginx -s reload 2>/dev/null || service nginx restart
